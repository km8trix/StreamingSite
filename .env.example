# Supabase — OPTIONAL for Milestone 1.
#
# When BOTH vars are set, the data layer (src/lib/data/*) queries Supabase.
# When EITHER is missing/empty, it transparently falls back to the bundled
# seed (src/lib/data/seed.json), so the app builds and renders offline.
#
# Copy this file to `.env.local` and fill in values from your Supabase
# project (Settings -> API). The anon key is safe to expose to the browser;
# it only grants the public-read policies defined in supabase/migrations.
#
# To populate a live DB: run supabase/migrations/0001_init.sql, then
# supabase/seed/seed.sql (e.g. via the Supabase SQL editor or `psql`).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site origin (scheme + host, no trailing slash) — used to build the
# "Sign in with Google" OAuth redirect (<origin>/auth/callback). RECOMMENDED in
# production so the redirect target is stable and matches the URL you allowlist
# in Supabase (Auth -> URL Configuration -> Redirect URLs). If unset, the app
# falls back to the request's host header (fine for local dev / previews).
#   e.g. https://senpai.vercel.app
# Google "Sign in with Google" also requires the Google provider to be enabled
# in the Supabase dashboard — see docs/google-oauth-setup.md.
NEXT_PUBLIC_SITE_URL=
