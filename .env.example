# Supabase — OPTIONAL for Milestone 1.
#
# When BOTH vars are set, the data layer (src/lib/data/*) queries Supabase.
# When EITHER is missing/empty, it transparently falls back to the bundled
# seed (src/lib/data/seed.json), so the app builds and renders offline.
#
# Copy this file to `.env.local` and fill in values from your Supabase
# project (Settings -> API). The anon key is safe to expose to the browser;
# it only grants the public-read policies defined in supabase/migrations.
#
# To populate a live DB: run supabase/migrations/0001_init.sql, then
# supabase/seed/seed.sql (e.g. via the Supabase SQL editor or `psql`).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# "Sign in with Google" (OAuth) needs no app env var — the OAuth redirect origin
# is derived from the request host automatically. You DO still configure the
# Google provider + the <your-domain>/auth/callback Redirect URL in the Supabase
# dashboard — see docs/google-oauth-setup.md.

# Upstash Redis — OPTIONAL. Powers the shared, cross-instance rate limiter on the
# public API routes (src/lib/rate-limit.ts). When BOTH are set, limits are a
# single global quota; when EITHER is missing the limiter falls back to a
# per-instance in-memory counter (fine for local dev, weaker in production).
#
# Provision via Vercel -> Storage -> Upstash for Redis (auto-injects these two),
# or create a DB at upstash.com and paste its REST URL + token here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry — OPTIONAL error monitoring (src/instrumentation*.ts, next.config.ts).
# All Sentry code is a no-op until a DSN is set, so the app runs fine without it.
# The Vercel Sentry integration sets the server SENTRY_DSN but NOT the
# NEXT_PUBLIC_ one — set NEXT_PUBLIC_SENTRY_DSN explicitly (it inlines at build
# time, so redeploy after changing it) or browser/Session-Replay events are
# dropped. SENTRY_ORG/PROJECT/AUTH_TOKEN are only needed to upload source maps.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Revenue (M3) — OPTIONAL. All public values (they ride in outbound URLs / the
# AdSense script tag), so NEXT_PUBLIC_ and not secret. Both inline at BUILD time —
# set in Vercel and redeploy. Empty = feature off (links untagged, no ads, and the
# AdSense CSP domains are not widened).
#
# Amazon Associates store tag — appended as ?tag= to amazon.* out-links
# (src/lib/affiliate.ts), used by WhereToWatch. Fires on amazon.com product/merch
# links (not today's streaming providers). e.g. senpai063-20
NEXT_PUBLIC_AFFILIATE_AMAZON=
# Google AdSense publisher client id — enables Auto Ads after cookie consent
# (src/components/AdSenseScript.tsx). MUST include the ca- prefix. In AdSense →
# Auto ads, disable Vignette/Anchor/Overlay to keep ads non-invasive. e.g.
# ca-pub-1191181818524233
NEXT_PUBLIC_ADSENSE_CLIENT=
